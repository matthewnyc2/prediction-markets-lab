{
  "contract_id": "C-I-BT-006",
  "interaction_id": "I-BT-006",
  "function": {
    "name": "handle_i_bt_006",
    "module_hint": "backend.handlers.backtest",
    "inputs": [
      {
        "name": "strategy_id",
        "type": "StrategyId"
      },
      {
        "name": "platforms",
        "type": "list[Platform]"
      },
      {
        "name": "date_range",
        "type": "DateRange"
      },
      {
        "name": "bankroll",
        "type": "int"
      }
    ],
    "outputs": [
      {
        "name": "backtest_result",
        "type": "BacktestResult"
      }
    ]
  },
  "behavior_inherited": {
    "async_mode": "async-await",
    "timeout_ms": 300000,
    "retry_policy": null,
    "concurrency_policy": "reject-if-another-running",
    "idempotency_rule": "idempotency-key-required-for-writes",
    "ui_locking_rule": "disable-run-and-show-progress-bar",
    "failure_transitions": [
      {
        "condition": "http-4xx-validation-error",
        "transition": "backtest",
        "ui_effect": "inline-error-beside-field"
      },
      {
        "condition": "http-5xx-server-error",
        "transition": "backtest",
        "ui_effect": "toast-retry-option"
      },
      {
        "condition": "network-timeout",
        "transition": "backtest",
        "ui_effect": "toast-check-connection"
      }
    ],
    "side_effects": [
      {
        "type": "db-write",
        "target": "backend database",
        "description": "persisted record"
      },
      {
        "type": "db-write",
        "target": "backtests + backtest_results",
        "description": "replay output persisted"
      },
      {
        "type": "db-read",
        "target": "price_ticks (historical)",
        "description": "event-driven replay"
      }
    ]
  },
  "preconditions": [
    {
      "ref": "INV-006",
      "condition": "backtest execute reads stored_price_history only; no live endpoint calls"
    },
    {
      "ref": "config",
      "condition": "strategy_id valid, platforms non-empty, date_range valid, bankroll >= 1"
    }
  ],
  "postconditions": [
    {
      "ref": "TS-02",
      "condition": "backtest_result has non-null final_equity, sharpe, brier, win_rate, equity_curve"
    },
    {
      "ref": "INV-006",
      "condition": "zero outbound calls to live adapter endpoints during run"
    }
  ],
  "references": {
    "validation_rule_refs": [
      "INV-006",
      "TS-02",
      "FS-003",
      "QU-R-*"
    ],
    "external_rule_refs": [],
    "source_state": "backtest",
    "success_transition": "backtest"
  }
}