{
  "contract_id": "C-I-STR-002",
  "interaction_id": "I-STR-002",
  "function": {
    "name": "handle_i_str_002",
    "module_hint": "backend.handlers.strategies",
    "inputs": [
      {
        "name": "strategy_id",
        "type": "StrategyId"
      },
      {
        "name": "state",
        "type": "Literal['on','off']"
      }
    ],
    "outputs": []
  },
  "behavior_inherited": {
    "async_mode": "async-await",
    "timeout_ms": 10000,
    "retry_policy": {
      "max_retries": 3,
      "backoff": "exponential",
      "base_ms": 250
    },
    "concurrency_policy": "queue-latest",
    "idempotency_rule": "idempotency-key-required-for-writes",
    "ui_locking_rule": "disable-submit-and-spin-until-response",
    "failure_transitions": [
      {
        "condition": "http-4xx-validation-error",
        "transition": "strategies",
        "ui_effect": "inline-error-beside-field"
      },
      {
        "condition": "http-5xx-server-error",
        "transition": "strategies",
        "ui_effect": "toast-retry-option"
      },
      {
        "condition": "network-timeout",
        "transition": "strategies",
        "ui_effect": "toast-check-connection"
      }
    ],
    "side_effects": [
      {
        "type": "db-write",
        "target": "backend database",
        "description": "persisted record"
      },
      {
        "type": "db-write",
        "target": "strategy_state_log",
        "description": "PR-002 audit log"
      }
    ]
  },
  "preconditions": [
    {
      "ref": "INV-003",
      "condition": "if transitioning to state='on', strategy.assigned_capital > 0"
    },
    {
      "ref": "INV-008",
      "condition": "sum(s.assigned_capital for s in strategies where s.state=='on') + new_capital <= equity"
    },
    {
      "ref": "INV-003",
      "condition": "assigned_capital > 0"
    },
    {
      "ref": "INV-008",
      "condition": "sum of on-strategy capital + this capital <= equity"
    }
  ],
  "postconditions": [
    {
      "ref": "PR-002",
      "condition": "strategy_state_log row appended with previous + new state"
    },
    {
      "ref": "CSC-001 or CSC-007",
      "condition": "dashboard active-strategies-panel reflects new state"
    }
  ],
  "references": {
    "validation_rule_refs": [
      "INV-003",
      "INV-008",
      "FS-001",
      "PR-002",
      "CSC-001"
    ],
    "external_rule_refs": [],
    "source_state": "strategies",
    "success_transition": "strategies"
  }
}